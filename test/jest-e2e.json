{
  "moduleFileExtensions": [
    "ts",
    "js",
    "json"
  ],
  "testEnvironment": "node",
  "setupFilesAfterEnv": [
    "<rootDir>/jest-e2e-setup.ts"
  ],
  "testMatch": [
    "**/*.e2e-spec.ts"
  ],
  "extensionsToTreatAsEsm": [
    ".ts"
  ],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "useESM": true,
        "tsconfig": "tsconfig.json"
      }
    ]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(isomorphic-dompurify)/)"
  ],
  "testTimeout": 30000,
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^isomorphic-dompurify$": "<rootDir>/mocks/isomorphic-dompurify.js"
  }
}